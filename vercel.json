{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": {
                "maxDuration": 60,
                "installCommand": "pip install -r requirements.txt",
                "includeFiles": [
                    "ads.txt"
                ]
            }
        }
    ],
    "build": {
        "env": {
            "ENABLE_EXPERIMENT_UV": "0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ]
}